      "verbose": true
    },
    {
      "name": "x86-release",
      "configurePreset": "x86-release",
      "configuration": "Release",
      "verbose": true
    }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-release",
